---
import SectionTitle from "../ui/SectionTitle.astro";
import config from "../../data/config.json";

const { siteOverview } = config;
---

<section class="bg-[#111111] py-24 md:py-36 border-t border-white/5">
  <div class="container mx-auto px-6">
    <SectionTitle title={siteOverview.titulo} />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-16">
      {siteOverview.items.map((card) => (
        <div class="bg-brand-gray-light p-8 border-b-[3px] border-brand-red flex flex-col items-start animate-on-scroll">
          <div class="text-brand-red mb-6">
            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="2"/>
            </svg>
          </div>
          
          <h3 class="font-condensed text-xl text-brand-white uppercase mb-2">
            {card.title}
          </h3>
          
          <p class="font-body text-sm text-brand-gray leading-relaxed mb-6">
            {card.description}
          </p>

          <a 
            href={card.href} 
            class="font-condensed text-brand-red tracking-widest text-sm hover:underline uppercase"
          >
            EXPLORAR →
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
