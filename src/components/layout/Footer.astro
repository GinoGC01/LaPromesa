---
import config from "../../data/config.json";

const { empresa, contacto, redes, footer } = config;

const links = {
  nav: [
    { label: "Inicio", href: "/" },
    { label: "Galería de Diseños", href: "/galeria" },
    { label: "Paleta de Colores", href: "/colores" },
    { label: "Sobre Nosotros", href: "/nosotros" },
  ],
  empresa: [
    { label: "Preguntas Frecuentes", href: "#" },
    { label: "Testimonios", href: "/testimonios" },
    { label: "Contacto", href: "/contacto" },
    { label: "Ubicación", href: "/contacto#mapa" },
  ],
};

const socialLinks = [
  { icon: "instagram", href: redes.instagram, label: "Instagram" },
  { icon: "facebook", href: redes.facebook, label: "Facebook" },
  { icon: "tiktok", href: redes.tiktok, label: "TikTok" },
];
---

<footer class="bg-brand-gray-light py-20 border-t border-white/5">
  <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Col 1: Brand -->
      <div class="flex flex-col gap-6">
        <a
          href="/"
          class="font-display text-3xl tracking-tighter text-brand-white"
        >
          {empresa.nombre.split(" ")[0]}<span class="text-brand-red"
            >{empresa.nombre.split(" ")[1]}</span
          >
        </a>
        <p class="font-body text-brand-gray text-sm leading-relaxed max-w-xs">
          {footer.descripcionCorta}
        </p>
        <div class="flex gap-4">
          {
            socialLinks
              .filter((s) => s.href)
              .map((social) => (
                <a
                  href={social.href}
                  class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-brand-white hover:bg-brand-red hover:border-brand-red transition-all"
                  aria-label={social.label}
                >
                  <span class="sr-only">{social.label}</span>
                  <div class="w-5 h-5 bg-current opacity-50" />
                </a>
              ))
          }
        </div>
      </div>

      <!-- Col 2: Nav -->
      <div>
        <h4
          class="font-condensed text-brand-white tracking-widest text-sm mb-6 uppercase"
        >
          Navegación
        </h4>
        <ul class="flex flex-col gap-3">
          {
            links.nav.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="font-body text-brand-gray text-sm hover:text-brand-red transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Col 3: Contact -->
      <div>
        <h4
          class="font-condensed text-brand-white tracking-widest text-sm mb-6 uppercase"
        >
          Contacto
        </h4>
        <ul class="flex flex-col gap-4">
          <li class="flex items-start gap-3">
            <span class="text-brand-red text-sm mt-1">📍</span>
            <span class="font-body text-brand-gray text-sm"
              >{contacto.direccion.calle}
              {contacto.direccion.numero}, {contacto.direccion.localidad}</span
            >
          </li>
          <li class="flex items-start gap-3">
            <span class="text-brand-red text-sm mt-1">📞</span>
            <span class="font-body text-brand-gray text-sm"
              >{contacto.telefono}</span
            >
          </li>
          <li class="flex items-start gap-3">
            <span class="text-brand-red text-sm mt-1">✉️</span>
            <span class="font-body text-brand-gray text-sm uppercase"
              >{contacto.email}</span
            >
          </li>
        </ul>
      </div>

      <!-- Col 4: Slogan/CTA -->
      <div class="bg-brand-black/30 p-8 rounded-[2px] border border-white/5">
        <h4 class="font-display text-2xl text-brand-white leading-tight mb-4">
          {footer.fraseCierre}
        </h4>
        <a
          href="/contacto"
          class="font-condensed text-brand-red text-xs tracking-[0.2em] hover:underline uppercase"
          >Comenzar un pedido →</a
        >
      </div>
    </div>

    <div
      class="mt-20 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <p class="font-body text-brand-gray text-xs tracking-widest">
        {footer.copyright}
      </p>
    </div>
  </div>
</footer>
