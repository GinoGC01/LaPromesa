---
interface Props {
  number: string;
  label: string;
}

const { number, label } = Astro.props;
---

<div class="flex flex-col items-center text-center p-6 bg-brand-gray-light/50 border border-brand-white/10 rounded-[2px] transition-transform hover:scale-105 duration-300">
  <span class="font-display text-5xl md:text-6xl text-brand-white mb-2">{number}</span>
  <span class="font-condensed text-sm md:text-base text-brand-white/80 tracking-[0.2em]">{label}</span>
</div>
